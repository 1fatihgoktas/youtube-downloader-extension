{\n  "manifest_version": 3,\n  "name": "YouTube Downloader Extension",\n  "version": "1.0",\n  "description": "Download YouTube videos in MP4 format with support for 720p and 1080p.",\n  "permissions": [\n    "downloads",\n    "activeTab",\n    "scripting"\n  ],\n  "background": {\n    "service_worker": "background.js"\n  },\n  "action": {\n    "default_popup": "popup.html",\n    "default_icon": "icon.png"\n  },\n  "icons": {\n    "16": "icon16.png",\n    "48": "icon48.png",\n    "128": "icon128.png"\n  },\n  "content_scripts": [\n    {\n      "matches": ["*://www.youtube.com/*"],\n      "js": ["content.js"]\n    }\n  ],\n  "web_accessible_resources": [\n    {\n      "resources": ["*.mp4"],\n      "matches": ["*://www.youtube.com/*"]\n    }\n  ]\n}